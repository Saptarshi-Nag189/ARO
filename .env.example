# ==============================================================================
# ARO — Environment Configuration
# ==============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Get free OpenRouter API keys at: https://openrouter.ai/keys
# ==============================================================================

# ─── API Keys (at minimum, set OPENROUTER_API_KEY) ────────────────────────────

# Default key — used for Trinity Large Preview (research, innovation, orchestrator)
# Also used as fallback for any model without a dedicated key
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional: Separate key for Step 3.5 Flash (planner, claim extraction)
# If blank, falls back to OPENROUTER_API_KEY
OPENROUTER_API_KEY_STEP=

# Optional: Separate key for GPT-OSS-120B (skeptic, synthesis, reflection)
# If blank, falls back to OPENROUTER_API_KEY
OPENROUTER_API_KEY_GPT_OSS=

# ─── Server Security ─────────────────────────────────────────────────────────

# Optional: API key to protect /api/ endpoints
# Leave empty to disable auth (development only)
ARO_API_KEY=

# ─── Server Configuration ────────────────────────────────────────────────────

# ARO_HOST=127.0.0.1
# ARO_PORT=5000
# ARO_MAX_CONCURRENT=3
