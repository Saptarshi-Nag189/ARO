# Required: Your OpenRouter API key
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional: API key to protect /api/ endpoints (leave empty to disable auth)
ARO_API_KEY=

# Optional: Server binding (defaults shown)
# ARO_HOST=127.0.0.1
# ARO_PORT=5000

# Optional: Max concurrent research sessions (default: 3)
# ARO_MAX_CONCURRENT=3
